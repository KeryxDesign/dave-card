---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Admin — Click Analytics">
  <style>
    body { padding: 40px 20px; }

    .admin {
      max-width: 560px;
      margin: 0 auto;
    }

    .admin-header {
      text-align: center;
      margin-bottom: 40px;
    }

    .admin-header h1 {
      font-family: 'Playfair Display', serif;
      font-size: 24px;
      font-weight: 600;
      background: linear-gradient(135deg, var(--gold), var(--gold-light));
      -webkit-background-clip: text;
      background-clip: text;
      -webkit-text-fill-color: transparent;
      margin-bottom: 8px;
    }

    .admin-header p {
      font-size: 13px;
      color: var(--text-dim);
    }

    .stats-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 14px;
      margin-bottom: 32px;
    }

    .stat-card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 20px;
      text-align: center;
    }

    .stat-card.total {
      grid-column: 1 / -1;
      border-color: var(--border-gold);
      background: linear-gradient(135deg, rgba(191, 155, 72, 0.05), var(--surface));
    }

    .stat-value {
      font-family: 'Playfair Display', serif;
      font-size: 32px;
      font-weight: 700;
      color: var(--gold);
      line-height: 1;
      margin-bottom: 6px;
    }

    .stat-card.total .stat-value { font-size: 42px; }

    .stat-label {
      font-size: 12px;
      font-weight: 500;
      color: var(--text-dim);
      text-transform: uppercase;
      letter-spacing: 1.5px;
    }

    .stat-last {
      font-size: 11px;
      color: var(--text-dim);
      margin-top: 6px;
      opacity: 0.7;
    }

    /* ── Table ── */
    .table-section {
      margin-bottom: 32px;
    }

    .table-section h2 {
      font-family: 'Playfair Display', serif;
      font-size: 14px;
      font-weight: 500;
      text-transform: uppercase;
      letter-spacing: 2px;
      color: var(--text-dim);
      margin-bottom: 16px;
      text-align: center;
    }

    .clicks-table {
      width: 100%;
      border-collapse: collapse;
    }

    .clicks-table th {
      font-size: 11px;
      font-weight: 600;
      color: var(--text-dim);
      text-transform: uppercase;
      letter-spacing: 1px;
      padding: 10px 14px;
      text-align: left;
      border-bottom: 1px solid var(--border);
    }

    .clicks-table th:last-child { text-align: right; }

    .clicks-table td {
      font-size: 13px;
      color: var(--text-muted);
      padding: 12px 14px;
      border-bottom: 1px solid rgba(26, 45, 80, 0.5);
    }

    .clicks-table td:last-child {
      text-align: right;
      font-weight: 600;
      color: var(--gold);
      font-family: 'Playfair Display', serif;
      font-size: 16px;
    }

    .clicks-table tr:hover td { color: var(--white); }
    .clicks-table tr:hover td:last-child { color: var(--gold-light); }

    .link-name {
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .link-dot {
      width: 8px;
      height: 8px;
      border-radius: 50%;
      flex-shrink: 0;
    }

    /* ── History ── */
    .history-section h2 {
      font-family: 'Playfair Display', serif;
      font-size: 14px;
      font-weight: 500;
      text-transform: uppercase;
      letter-spacing: 2px;
      color: var(--text-dim);
      margin-bottom: 16px;
      text-align: center;
    }

    .history-list {
      list-style: none;
      max-height: 300px;
      overflow-y: auto;
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 4px 0;
    }

    .history-list::-webkit-scrollbar { width: 4px; }
    .history-list::-webkit-scrollbar-track { background: transparent; }
    .history-list::-webkit-scrollbar-thumb { background: var(--border); border-radius: 4px; }

    .history-item {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 10px 16px;
      font-size: 12px;
      border-bottom: 1px solid rgba(26, 45, 80, 0.3);
    }

    .history-item:last-child { border-bottom: none; }

    .history-item .label { color: var(--text-muted); font-weight: 500; }
    .history-item .time { color: var(--text-dim); font-size: 11px; font-family: monospace; }

    /* ── Actions ── */
    .actions {
      display: flex;
      gap: 12px;
      margin-top: 32px;
    }

    .btn {
      flex: 1;
      padding: 12px 16px;
      border: 1px solid var(--border);
      border-radius: var(--radius);
      background: var(--surface);
      color: var(--text-muted);
      font-family: 'Inter', sans-serif;
      font-size: 12px;
      font-weight: 600;
      cursor: pointer;
      text-align: center;
      text-decoration: none;
      transition: all 0.3s var(--transition);
    }

    .btn:hover { border-color: var(--gold); color: var(--gold); }

    .btn--danger:hover { border-color: #e74c3c; color: #e74c3c; }

    .empty-state {
      text-align: center;
      padding: 60px 20px;
      color: var(--text-dim);
      font-size: 14px;
    }

    .empty-state .icon { font-size: 40px; margin-bottom: 16px; opacity: 0.5; }

    @media (max-width: 480px) {
      body { padding: 24px 16px; }
      .stats-grid { grid-template-columns: 1fr; }
      .stat-card.total .stat-value { font-size: 36px; }
    }
  </style>

  <div class="admin">
    <div class="admin-header">
      <h1>Click Analytics</h1>
      <p>Link performance for your digital card</p>
    </div>

    <div id="content">
      <div class="empty-state">
        <div class="icon">📊</div>
        <p>Loading analytics...</p>
      </div>
    </div>
  </div>

  <script>
    const CLICKS_KEY = 'dave-card-clicks';

    const LINK_META: Record<string, { label: string; color: string }> = {
      'keryx-design': { label: 'Keryx Design', color: '#bf9b48' },
      'websites': { label: 'Websites That Convert', color: '#d4b060' },
      'linkedin': { label: 'LinkedIn', color: '#0a66c2' },
      'email': { label: 'Email', color: '#8a96ab' },
      'hotaru42': { label: 'Hotaru42', color: '#9b59b6' },
      'whatsapp': { label: 'WhatsApp', color: '#25D366' },
    };

    function getClicks(): Record<string, { count: number; last: string; history: string[] }> {
      try { return JSON.parse(localStorage.getItem(CLICKS_KEY) || '{}'); }
      catch { return {}; }
    }

    function timeAgo(iso: string): string {
      const diff = Date.now() - new Date(iso).getTime();
      const mins = Math.floor(diff / 60000);
      if (mins < 1) return 'just now';
      if (mins < 60) return `${mins}m ago`;
      const hrs = Math.floor(mins / 60);
      if (hrs < 24) return `${hrs}h ago`;
      const days = Math.floor(hrs / 24);
      return `${days}d ago`;
    }

    function formatDate(iso: string): string {
      const d = new Date(iso);
      return d.toLocaleDateString('en-GB', { day: '2-digit', month: 'short' }) + ' ' +
             d.toLocaleTimeString('en-GB', { hour: '2-digit', minute: '2-digit' });
    }

    function render() {
      const clicks = getClicks();
      const container = document.getElementById('content')!;
      const entries = Object.entries(clicks).sort((a, b) => b[1].count - a[1].count);
      const totalClicks = entries.reduce((s, [, v]) => s + v.count, 0);

      if (totalClicks === 0) {
        container.innerHTML = `
          <div class="empty-state">
            <div class="icon">📊</div>
            <p>No clicks yet. Share your card link to start tracking.</p>
          </div>
          <div class="actions">
            <a href="${import.meta.env.BASE_URL}" class="btn">← Back to Card</a>
          </div>`;
        return;
      }

      // Build all recent history items
      const allHistory: { name: string; time: string }[] = [];
      for (const [name, data] of entries) {
        for (const ts of data.history || []) {
          allHistory.push({ name, time: ts });
        }
      }
      allHistory.sort((a, b) => b.time.localeCompare(a.time));
      const recentHistory = allHistory.slice(0, 50);

      container.innerHTML = `
        <!-- Total -->
        <div class="stats-grid">
          <div class="stat-card total">
            <div class="stat-value">${totalClicks}</div>
            <div class="stat-label">Total Clicks</div>
          </div>
          ${entries.slice(0, 4).map(([name, data]) => `
            <div class="stat-card">
              <div class="stat-value">${data.count}</div>
              <div class="stat-label">${(LINK_META[name]?.label || name)}</div>
              ${data.last ? `<div class="stat-last">${timeAgo(data.last)}</div>` : ''}
            </div>
          `).join('')}
        </div>

        <!-- Table -->
        <div class="table-section">
          <h2>All Links</h2>
          <table class="clicks-table">
            <thead>
              <tr><th>Link</th><th>Clicks</th></tr>
            </thead>
            <tbody>
              ${entries.map(([name, data]) => `
                <tr>
                  <td>
                    <div class="link-name">
                      <span class="link-dot" style="background:${LINK_META[name]?.color || '#556178'}"></span>
                      ${LINK_META[name]?.label || name}
                    </div>
                  </td>
                  <td>${data.count}</td>
                </tr>
              `).join('')}
            </tbody>
          </table>
        </div>

        <!-- Recent Activity -->
        <div class="history-section">
          <h2>Recent Activity</h2>
          <ul class="history-list">
            ${recentHistory.map(h => `
              <li class="history-item">
                <span class="label">${LINK_META[h.name]?.label || h.name}</span>
                <span class="time">${formatDate(h.time)}</span>
              </li>
            `).join('')}
          </ul>
        </div>

        <!-- Actions -->
        <div class="actions">
          <a href="${import.meta.env.BASE_URL}" class="btn">← Back to Card</a>
          <button class="btn btn--danger" id="btn-reset">Reset All Data</button>
        </div>`;

      document.getElementById('btn-reset')?.addEventListener('click', () => {
        if (confirm('Are you sure? This will delete all click data.')) {
          localStorage.removeItem(CLICKS_KEY);
          render();
        }
      });
    }

    render();
  </script>
</Layout>
