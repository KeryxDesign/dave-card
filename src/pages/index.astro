  <script>
    // ── i18n ──
    (function() {
      const STORAGE_KEY = 'dave-card-lang';
      const saved = localStorage.getItem(STORAGE_KEY);
      let lang: string;

      if (saved === 'it' || saved === 'en') {
        lang = saved;
      } else {
        const browserLang = (navigator.language || 'en').toLowerCase();
        lang = browserLang.startsWith('it') ? 'it' : 'en';
      }

      function setLang(l: string) {
        lang = l;
        localStorage.setItem(STORAGE_KEY, l);
        document.documentElement.setAttribute('data-lang', l);
        document.documentElement.lang = l;

        document.getElementById('btn-it')!.classList.toggle('active', l === 'it');
        document.getElementById('btn-en')!.classList.toggle('active', l === 'en');

        document.title = 'Dave Filippini — Direct Response Designer';

        const waMsg = l === 'it'
          ? 'Ciao Dave! Ti contatto dal tuo sito personale. Vorrei saperne di più sui tuoi servizi.'
          : "Hi Dave! I found you through your personal site. I'd like to learn more about your services.";
        document.getElementById('wa-fab')!.setAttribute('href',
          'https://wa.me/355695822380?text=' + encodeURIComponent(waMsg));

        const websiteCard = document.getElementById('website-card');
        if (websiteCard) {
          websiteCard.setAttribute('href', l === 'it'
            ? 'https://keryxdesign.com/it/keryxsite'
            : 'https://keryxdesign.com/it/keryxsite');
        }
      }

      setLang(lang);
      document.getElementById('btn-it')!.addEventListener('click', () => setLang('it'));
      document.getElementById('btn-en')!.addEventListener('click', () => setLang('en'));
    })();

    // ── Click Tracking ──
    (function() {
      const CLICKS_KEY = 'dave-card-clicks';

      function getClicks(): Record<string, { count: number; last: string; history: string[] }> {
        try { return JSON.parse(localStorage.getItem(CLICKS_KEY) || '{}'); }
        catch { return {}; }
      }

      function trackClick(name: string) {
        const clicks = getClicks();
        const now = new Date().toISOString();
        if (!clicks[name]) clicks[name] = { count: 0, last: '', history: [] };
        clicks[name].count++;
        clicks[name].last = now;
        clicks[name].history.push(now);
        // Keep only last 100 entries per link
        if (clicks[name].history.length > 100) clicks[name].history = clicks[name].history.slice(-100);
        localStorage.setItem(CLICKS_KEY, JSON.stringify(clicks));
      }

      document.querySelectorAll('[data-track]').forEach(el => {
        el.addEventListener('click', () => {
          const name = (el as HTMLElement).dataset.track!;
          trackClick(name);
        });
      });
    })();
  </script>
