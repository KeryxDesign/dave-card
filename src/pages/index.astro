---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Dave Filippini — Direct Response Designer">
  <style>
    body {
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 40px 20px;
      position: relative;
    }

    /* Subtle grain texture */
    body::before {
      content: '';
      position: fixed;
      inset: 0;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.03'/%3E%3C/svg%3E");
      pointer-events: none;
      z-index: 0;
    }

    .card {
      width: 100%;
      max-width: 440px;
      position: relative;
      z-index: 1;
    }

    /* ── Language Toggle ── */
    .lang-toggle {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 6px;
      margin-bottom: 28px;
    }

    .lang-btn {
      display: flex;
      align-items: center;
      gap: 6px;
      background: transparent;
      border: 1px solid transparent;
      border-radius: 8px;
      padding: 6px 12px;
      cursor: pointer;
      font-family: 'Inter', sans-serif;
      font-size: 12px;
      font-weight: 500;
      color: var(--text-dim);
      transition: all 0.3s var(--transition);
    }

    .lang-btn:hover { color: var(--text-muted); }

    .lang-btn.active {
      color: var(--gold);
      border-color: var(--border-gold);
      background: var(--gold-glow);
    }

    .lang-btn .flag { font-size: 16px; line-height: 1; }

    .lang-sep { color: var(--text-dim); font-size: 12px; opacity: 0.4; }

    /* ── Avatar ── */
    .avatar {
      width: 100px;
      height: 100px;
      border-radius: 50%;
      object-fit: cover;
      object-position: center 20%;
      border: 2px solid var(--border-gold);
      box-shadow: 0 0 30px var(--gold-glow);
      margin: 0 auto 20px;
      display: block;
    }

    /* ── Header ── */
    .header { text-align: center; margin-bottom: 24px; }

    .name {
      font-family: 'Playfair Display', serif;
      font-size: 34px;
      font-weight: 600;
      line-height: 1.2;
      background: linear-gradient(135deg, var(--gold) 0%, var(--gold-light) 50%, var(--gold) 100%);
      -webkit-background-clip: text;
      background-clip: text;
      -webkit-text-fill-color: transparent;
      margin-bottom: 10px;
    }

    .tagline {
      font-family: 'Inter', sans-serif;
      font-size: 12px;
      font-weight: 600;
      color: var(--gold-muted);
      text-transform: uppercase;
      letter-spacing: 3.5px;
    }

    /* ── Bio ── */
    .bio {
      text-align: center;
      font-size: 14px;
      font-weight: 300;
      line-height: 1.8;
      color: var(--text-muted);
      margin-bottom: 32px;
      padding: 0 8px;
    }

    .bio strong { color: var(--white); font-weight: 600; }

    /* ── Testimonials Carousel ── */
    .testimonials {
      margin-bottom: 32px;
      position: relative;
      overflow: hidden;
      mask-image: linear-gradient(90deg, transparent, black 8%, black 92%, transparent);
      -webkit-mask-image: linear-gradient(90deg, transparent, black 8%, black 92%, transparent);
    }

    .testimonials__track {
      display: flex;
      gap: 16px;
      animation: scroll-testimonials 35s linear infinite;
      width: max-content;
    }

    .testimonials__track:hover { animation-play-state: paused; }

    @keyframes scroll-testimonials {
      0% { transform: translateX(0); }
      100% { transform: translateX(-50%); }
    }

    .testimonial {
      flex-shrink: 0;
      width: 280px;
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 18px 20px;
      position: relative;
    }

    .testimonial__quote {
      font-size: 13px;
      font-weight: 300;
      font-style: italic;
      line-height: 1.6;
      color: var(--text-muted);
      margin-bottom: 12px;
    }

    .testimonial__quote::before {
      content: '\201C';
      font-family: 'Playfair Display', serif;
      font-size: 28px;
      font-style: normal;
      color: var(--gold);
      opacity: 0.5;
      line-height: 0;
      vertical-align: -0.35em;
      margin-right: 2px;
    }

    .testimonial__author {
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .testimonial__avatar {
      width: 28px;
      height: 28px;
      border-radius: 50%;
      border: 1px solid var(--border-gold);
      flex-shrink: 0;
      object-fit: cover;
    }

    .testimonial__info { min-width: 0; }

    .testimonial__name {
      font-size: 12px;
      font-weight: 600;
      color: var(--white);
      line-height: 1.3;
    }

    .testimonial__role {
      font-size: 11px;
      font-weight: 400;
      color: var(--text-dim);
      line-height: 1.3;
    }

    @media (max-width: 480px) {
      .testimonial { width: 250px; padding: 14px 16px; }
      .testimonial__quote { font-size: 12px; }
    }

    /* ── Divider ── */
    .divider {
      height: 1px;
      background: linear-gradient(90deg, transparent, var(--gold), transparent);
      opacity: 0.15;
      margin: 0 0 32px 0;
    }

    /* ── Section Label ── */
    .section-label {
      font-family: 'Playfair Display', serif;
      font-size: 13px;
      font-weight: 500;
      text-transform: uppercase;
      letter-spacing: 3px;
      color: var(--text-dim);
      text-align: center;
      margin-bottom: 18px;
    }

    /* ── Service Cards ── */
    .services-grid { display: flex; flex-direction: column; gap: 14px; margin-bottom: 32px; }

    .service-card {
      display: block;
      text-decoration: none;
      color: inherit;
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 22px 20px;
      position: relative;
      overflow: hidden;
      transition: border-color 0.35s var(--transition), transform 0.35s var(--transition), box-shadow 0.35s var(--transition);
    }

    .service-card::before {
      content: '';
      position: absolute;
      inset: 0;
      background: linear-gradient(135deg, var(--gold-glow), transparent);
      opacity: 0;
      transition: opacity 0.35s var(--transition);
      pointer-events: none;
    }

    .service-card:hover {
      border-color: var(--gold);
      transform: translateY(-3px);
      box-shadow: 0 12px 40px rgba(191, 155, 72, 0.1);
    }

    .service-card:hover::before { opacity: 1; }
    .service-card:hover .service-card__arrow { opacity: 1; transform: translateX(0); }
    .service-card:hover .service-card__icon svg { stroke: var(--gold); }

    .service-card--featured {
      border-color: var(--border-gold);
      background: linear-gradient(135deg, rgba(191, 155, 72, 0.05), var(--surface));
    }

    .service-card__row {
      display: flex;
      align-items: flex-start;
      gap: 16px;
      position: relative;
      z-index: 1;
    }

    .service-card__icon {
      flex-shrink: 0;
      width: 42px;
      height: 42px;
      display: flex;
      align-items: center;
      justify-content: center;
      border-radius: 10px;
      background: rgba(191, 155, 72, 0.08);
      border: 1px solid rgba(191, 155, 72, 0.1);
    }

    .service-card__icon svg {
      width: 20px;
      height: 20px;
      stroke: var(--text-muted);
      fill: none;
      transition: stroke 0.35s var(--transition);
    }

    .service-card__content { flex: 1; min-width: 0; }

    .service-card__title {
      font-family: 'Playfair Display', serif;
      font-size: 16px;
      font-weight: 600;
      margin-bottom: 4px;
      color: var(--white);
    }

    .service-card__desc { font-size: 13px; font-weight: 400; color: var(--text-muted); line-height: 1.5; }

    .service-card__badge {
      display: inline-block;
      margin-top: 10px;
      font-size: 11px;
      font-weight: 700;
      color: var(--gold);
      background: rgba(191, 155, 72, 0.1);
      border: 1px solid rgba(191, 155, 72, 0.2);
      border-radius: 100px;
      padding: 5px 14px;
      letter-spacing: 0.5px;
    }

    .service-card__arrow {
      flex-shrink: 0;
      display: flex;
      align-items: center;
      align-self: center;
      opacity: 0;
      transform: translateX(-8px);
      transition: opacity 0.35s var(--transition), transform 0.35s var(--transition);
      color: var(--gold);
    }

    .service-card__arrow svg { width: 18px; height: 18px; stroke: var(--gold); fill: none; }

    /* ── Connect Buttons ── */
    .connect-row { display: flex; gap: 10px; margin-bottom: 32px; }

    .connect-btn {
      flex: 1;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      text-decoration: none;
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 13px 10px;
      color: var(--text-muted);
      font-family: 'Inter', sans-serif;
      font-size: 12px;
      font-weight: 500;
      transition: border-color 0.35s var(--transition), color 0.35s var(--transition), transform 0.35s var(--transition);
    }

    .connect-btn:hover { border-color: var(--gold); color: var(--gold); transform: translateY(-2px); }

    .connect-btn svg { width: 16px; height: 16px; flex-shrink: 0; transition: fill 0.35s var(--transition), stroke 0.35s var(--transition); }
    .connect-btn:hover svg { fill: var(--gold); stroke: var(--gold); }

    .connect-btn--wa { border-color: rgba(37, 211, 102, 0.25); }
    .connect-btn--wa:hover { border-color: #25D366; color: #25D366; }
    .connect-btn--wa:hover svg { fill: #25D366; }

    /* ── Footer ── */
    .footer { text-align: center; padding-top: 8px; }

    .status {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      font-size: 11px;
      font-weight: 500;
      color: var(--text-dim);
      letter-spacing: 0.5px;
    }

    .status-dot {
      width: 6px;
      height: 6px;
      border-radius: 50%;
      background: var(--gold);
      box-shadow: 0 0 8px rgba(191, 155, 72, 0.6);
      animation: pulse 2.5s ease-in-out infinite;
    }

    @keyframes pulse {
      0%, 100% { opacity: 1; box-shadow: 0 0 8px rgba(191, 155, 72, 0.6); }
      50% { opacity: 0.4; box-shadow: 0 0 16px rgba(191, 155, 72, 0.3); }
    }

    /* ── Logo icons ── */
    .service-card__icon--logo { background: transparent; border: none; }
    .service-card__icon--logo svg { width: 28px; height: 28px; stroke: none; }

    /* ── i18n ── */
    [data-lang-en] { display: none; }
    [data-lang-it] { display: none; }
    html[data-lang="en"] [data-lang-en] { display: inline; }
    html[data-lang="it"] [data-lang-it] { display: inline; }
    html[data-lang="en"] [data-lang-en].d-block { display: block; }
    html[data-lang="it"] [data-lang-it].d-block { display: block; }
    html[data-lang="en"] [data-lang-en].d-flex { display: flex; }
    html[data-lang="it"] [data-lang-it].d-flex { display: flex; }

    /* ── Mobile ── */
    @media (max-width: 480px) {
      body { padding: 28px 16px; align-items: flex-start; }
      .name { font-size: 28px; }
      .tagline { font-size: 11px; letter-spacing: 2.5px; }
      .bio { font-size: 13px; padding: 0; }
      .service-card { padding: 18px 16px; }
      .service-card__icon { width: 38px; height: 38px; }
      .connect-btn { padding: 11px 8px; font-size: 11px; gap: 6px; }
      .connect-btn svg { width: 14px; height: 14px; }
    }
  </style>

  <div class="card">
    <!-- Language Toggle -->
    <div class="lang-toggle">
