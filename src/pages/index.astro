      </button>
      <span class="lang-sep">|</span>
      <button class="lang-btn" data-set-lang="en" id="btn-en">
        <span class="flag">&#127468;&#127463;</span> EN
      </button>
    </div>

    <!-- Header -->
    <header class="header">
      <img src={`${import.meta.env.BASE_URL}dave.jpg`} alt="Dave Filippini" class="avatar" />
      <h1 class="name">Dave Filippini</h1>
      <p class="tagline">
        <span data-lang-en>I Give Ideas a Voice</span>
        <span data-lang-it>Do Voce alle Idee</span>
      </p>
    </header>

