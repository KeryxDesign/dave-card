---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Dave Filippini — Direct Response Designer">
  <style>
    body {
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 40px 20px;
      position: relative;
    }

    /* Subtle grain texture */
    body::before {
      content: '';
      position: fixed;
      inset: 0;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.03'/%3E%3C/svg%3E");
      pointer-events: none;
      z-index: 0;
    }

    .card {
      width: 100%;
      max-width: 440px;
      position: relative;
      z-index: 1;
    }

    /* ── Language Toggle ── */
    .lang-toggle {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 6px;
      margin-bottom: 28px;
    }

    .lang-btn {
      display: flex;
      align-items: center;
      gap: 6px;
      background: transparent;
      border: 1px solid transparent;
      border-radius: 8px;
      padding: 6px 12px;
      cursor: pointer;
      font-family: 'Inter', sans-serif;
      font-size: 12px;
      font-weight: 500;
      color: var(--text-dim);
      transition: all 0.3s var(--transition);
    }

    .lang-btn:hover { color: var(--text-muted); }

    .lang-btn.active {
      color: var(--gold);
      border-color: var(--border-gold);
      background: var(--gold-glow);
    }

    .lang-btn .flag { font-size: 16px; line-height: 1; }

    .lang-sep { color: var(--text-dim); font-size: 12px; opacity: 0.4; }

    /* ── Avatar ── */
    .avatar {
      width: 100px;
      height: 100px;
      border-radius: 50%;
      object-fit: cover;
      object-position: center 20%;
      border: 2px solid var(--border-gold);
      box-shadow: 0 0 30px var(--gold-glow);
      margin: 0 auto 20px;
      display: block;
    }

    /* ── Header ── */
    .header { text-align: center; margin-bottom: 24px; }

    .name {
      font-family: 'Playfair Display', serif;
      font-size: 34px;
      font-weight: 600;
      line-height: 1.2;
      background: linear-gradient(135deg, var(--gold) 0%, var(--gold-light) 50%, var(--gold) 100%);
      -webkit-background-clip: text;
      background-clip: text;
      -webkit-text-fill-color: transparent;
      margin-bottom: 10px;
    }

    .tagline {
      font-family: 'Inter', sans-serif;
      font-size: 12px;
      font-weight: 600;
      color: var(--gold-muted);
      text-transform: uppercase;
      letter-spacing: 3.5px;
    }

    /* ── Bio ── */
    .bio {
      text-align: center;
      font-size: 14px;
      font-weight: 300;
      line-height: 1.8;
      color: var(--text-muted);
      margin-bottom: 32px;
      padding: 0 8px;
    }

    .bio strong { color: var(--white); font-weight: 600; }

    /* ── Divider ── */
    .divider {
      height: 1px;
      background: linear-gradient(90deg, transparent, var(--gold), transparent);
      opacity: 0.15;
      margin: 0 0 32px 0;
    }

    /* ── Section Label ── */
    .section-label {
      font-family: 'Playfair Display', serif;
      font-size: 13px;
      font-weight: 500;
      text-transform: uppercase;
      letter-spacing: 3px;
      color: var(--text-dim);
      text-align: center;
      margin-bottom: 18px;
    }

    /* ── Service Cards ── */
    .services-grid { display: flex; flex-direction: column; gap: 14px; margin-bottom: 32px; }

    .service-card {
      display: block;
      text-decoration: none;
      color: inherit;
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 22px 20px;
      position: relative;
      overflow: hidden;
      transition: border-color 0.35s var(--transition), transform 0.35s var(--transition), box-shadow 0.35s var(--transition);
    }

    .service-card::before {
      content: '';
      position: absolute;
      inset: 0;
      background: linear-gradient(135deg, var(--gold-glow), transparent);
      opacity: 0;
      transition: opacity 0.35s var(--transition);
      pointer-events: none;
    }

    .service-card:hover {
      border-color: var(--gold);
      transform: translateY(-3px);
      box-shadow: 0 12px 40px rgba(191, 155, 72, 0.1);
    }

    .service-card:hover::before { opacity: 1; }
    .service-card:hover .service-card__arrow { opacity: 1; transform: translateX(0); }
    .service-card:hover .service-card__icon svg { stroke: var(--gold); }

    .service-card--featured {
      border-color: var(--border-gold);
      background: linear-gradient(135deg, rgba(191, 155, 72, 0.05), var(--surface));
    }

    .service-card__row {
      display: flex;
      align-items: flex-start;
      gap: 16px;
      position: relative;
      z-index: 1;
    }

    .service-card__icon {
      flex-shrink: 0;
      width: 42px;
      height: 42px;
      display: flex;
      align-items: center;
      justify-content: center;
      border-radius: 10px;
      background: rgba(191, 155, 72, 0.08);
      border: 1px solid rgba(191, 155, 72, 0.1);
    }

    .service-card__icon svg {
      width: 20px;
      height: 20px;
      stroke: var(--text-muted);
      fill: none;
      transition: stroke 0.35s var(--transition);
    }

    .service-card__content { flex: 1; min-width: 0; }

    .service-card__title {
      font-family: 'Playfair Display', serif;
      font-size: 16px;
      font-weight: 600;
      margin-bottom: 4px;
      color: var(--white);
    }

    .service-card__desc { font-size: 13px; font-weight: 400; color: var(--text-muted); line-height: 1.5; }

    .service-card__badge {
      display: inline-block;
      margin-top: 10px;
      font-size: 11px;
      font-weight: 700;
      color: var(--gold);
      background: rgba(191, 155, 72, 0.1);
      border: 1px solid rgba(191, 155, 72, 0.2);
      border-radius: 100px;
      padding: 5px 14px;
      letter-spacing: 0.5px;
    }

    .service-card__arrow {
      flex-shrink: 0;
      display: flex;
      align-items: center;
      align-self: center;
      opacity: 0;
      transform: translateX(-8px);
      transition: opacity 0.35s var(--transition), transform 0.35s var(--transition);
      color: var(--gold);
    }

    .service-card__arrow svg { width: 18px; height: 18px; stroke: var(--gold); fill: none; }

    /* ── Connect Buttons ── */
    .connect-row { display: flex; gap: 12px; margin-bottom: 32px; }

    .connect-btn {
      flex: 1;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
      text-decoration: none;
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 14px 16px;
      color: var(--text-muted);
      font-family: 'Inter', sans-serif;
      font-size: 13px;
      font-weight: 500;
      transition: border-color 0.35s var(--transition), color 0.35s var(--transition), transform 0.35s var(--transition);
    }

    .connect-btn:hover { border-color: var(--gold); color: var(--gold); transform: translateY(-2px); }

    .connect-btn svg { width: 18px; height: 18px; flex-shrink: 0; transition: fill 0.35s var(--transition), stroke 0.35s var(--transition); }
    .connect-btn:hover svg { fill: var(--gold); stroke: var(--gold); }

    /* ── After Hours ── */
    .link-card {
      display: block;
      text-decoration: none;
      color: inherit;
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 18px 20px;
      margin-bottom: 32px;
      position: relative;
      overflow: hidden;
      transition: border-color 0.35s var(--transition), transform 0.35s var(--transition), box-shadow 0.35s var(--transition);
    }

    .link-card:hover { border-color: var(--gold); transform: translateY(-2px); box-shadow: 0 8px 32px var(--gold-glow); }
    .link-card:hover .service-card__arrow { opacity: 1; transform: translateX(0); }
    .link-card:hover .service-card__icon svg { stroke: var(--gold); }

    /* ── Footer ── */
    .footer { text-align: center; padding-top: 8px; }

    .status {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      font-size: 11px;
      font-weight: 500;
      color: var(--text-dim);
      letter-spacing: 0.5px;
    }

    .status-dot {
      width: 6px;
      height: 6px;
      border-radius: 50%;
      background: var(--gold);
      box-shadow: 0 0 8px rgba(191, 155, 72, 0.6);
      animation: pulse 2.5s ease-in-out infinite;
    }

    @keyframes pulse {
      0%, 100% { opacity: 1; box-shadow: 0 0 8px rgba(191, 155, 72, 0.6); }
      50% { opacity: 0.4; box-shadow: 0 0 16px rgba(191, 155, 72, 0.3); }
    }

    /* ── WhatsApp FAB ── */
    .whatsapp-fab {
      position: fixed;
      bottom: 28px;
      right: 28px;
      z-index: 100;
      display: flex;
      align-items: center;
      gap: 10px;
      background: linear-gradient(135deg, #25D366 0%, #128C7E 100%);
      color: #fff;
      text-decoration: none;
      border-radius: 60px;
      padding: 14px 22px 14px 18px;
      font-family: 'Inter', sans-serif;
      font-size: 14px;
      font-weight: 600;
      box-shadow: 0 6px 24px rgba(37, 211, 102, 0.35);
      transition: transform 0.3s var(--transition), box-shadow 0.3s var(--transition);
    }

    .whatsapp-fab:hover { transform: translateY(-3px) scale(1.03); box-shadow: 0 10px 36px rgba(37, 211, 102, 0.45); }
    .whatsapp-fab svg { width: 22px; height: 22px; fill: #fff; flex-shrink: 0; }

    /* ── i18n ── */
    [data-lang-en] { display: none; }
    [data-lang-it] { display: none; }
    html[data-lang="en"] [data-lang-en] { display: inline; }
    html[data-lang="it"] [data-lang-it] { display: inline; }
    html[data-lang="en"] [data-lang-en].d-block { display: block; }
    html[data-lang="it"] [data-lang-it].d-block { display: block; }
    html[data-lang="en"] [data-lang-en].d-flex { display: flex; }
    html[data-lang="it"] [data-lang-it].d-flex { display: flex; }

    /* ── Mobile ── */
    @media (max-width: 480px) {
      body { padding: 28px 16px; align-items: flex-start; }
      .name { font-size: 28px; }
      .tagline { font-size: 11px; letter-spacing: 2.5px; }
      .bio { font-size: 13px; padding: 0; }
      .service-card { padding: 18px 16px; }
      .service-card__icon { width: 38px; height: 38px; }
      .connect-btn { padding: 12px 12px; font-size: 12px; }
      .whatsapp-fab { bottom: 18px; right: 18px; padding: 12px 18px 12px 14px; font-size: 13px; }
      .whatsapp-fab svg { width: 20px; height: 20px; }
    }
  </style>

  <div class="card">
    <!-- Language Toggle -->
    <div class="lang-toggle">
      <button class="lang-btn" data-set-lang="it" id="btn-it">
        <span class="flag">&#127470;&#127481;</span> IT
      </button>
      <span class="lang-sep">|</span>
      <button class="lang-btn" data-set-lang="en" id="btn-en">
        <span class="flag">&#127468;&#127463;</span> EN
      </button>
    </div>

    <!-- Header -->
    <header class="header">
      <img src={`${import.meta.env.BASE_URL}dave.jpg`} alt="Dave Filippini" class="avatar" />
      <h1 class="name">Dave Filippini</h1>
      <p class="tagline">
        <span data-lang-en>I Give Ideas a Voice</span>
        <span data-lang-it>Do Voce alle Idee</span>
      </p>
    </header>

    <!-- Bio -->
    <p class="bio">
      <span data-lang-en>I build brands that <strong>get noticed</strong> and design websites that <strong>convert</strong>. If you have a project, a product, or a vision &mdash; I give it a coherent voice, a face, and a strategy to reach the right people.</span>
      <span data-lang-it>Creo brand che <strong>si fanno notare</strong> e progetto siti web che <strong>convertono</strong>. Se hai un progetto, un prodotto o una visione &mdash; gli do una voce coerente, un volto e una strategia per raggiungere le persone giuste.</span>
    </p>

    <div class="divider"></div>

    <!-- What I Do -->
    <p class="section-label">
      <span data-lang-en>What I Do</span>
      <span data-lang-it>Cosa Faccio</span>
    </p>

    <div class="services-grid">
      <a href="https://keryxdesign.com" target="_blank" rel="noopener noreferrer" class="service-card service-card--featured" data-track="keryx-design">
        <div class="service-card__row">
          <div class="service-card__icon">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M7.5 3.75H6A2.25 2.25 0 0 0 3.75 6v1.5M16.5 3.75H18A2.25 2.25 0 0 1 20.25 6v1.5m0 9V18A2.25 2.25 0 0 1 18 20.25h-1.5m-9 0H6A2.25 2.25 0 0 1 3.75 18v-1.5M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
            </svg>
          </div>
          <div class="service-card__content">
            <div class="service-card__title">Direct Response Designer</div>
            <div class="service-card__desc">
              <span data-lang-en>Branding, strategy &amp; design that drives action and measurable results.</span>
              <span data-lang-it>Branding, strategia &amp; design che spinge all'azione e genera risultati misurabili.</span>
            </div>
          </div>
          <div class="service-card__arrow">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" /></svg>
          </div>
        </div>
      </a>

      <a href="https://keryxdesign.com/it/keryxsite" target="_blank" rel="noopener noreferrer" class="service-card" id="website-card" data-track="websites">
        <div class="service-card__row">
          <div class="service-card__icon">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17.25 6.75 22.5 12l-5.25 5.25m-10.5 0L1.5 12l5.25-5.25m7.5-3-4.5 16.5" />
            </svg>
          </div>
          <div class="service-card__content">
            <div class="service-card__title">
              <span data-lang-en>Websites That Convert</span>
              <span data-lang-it>Siti Web Che Convertono</span>
            </div>
            <div class="service-card__desc">
              <span data-lang-en>Professional websites designed to turn visitors into customers.</span>
              <span data-lang-it>Siti web professionali progettati per trasformare visitatori in clienti.</span>
            </div>
            <div class="service-card__badge">
              <span data-lang-en>From $320</span>
              <span data-lang-it>Da 297&euro;</span>
            </div>
          </div>
          <div class="service-card__arrow">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" /></svg>
          </div>
        </div>
      </a>
    </div>

    <div class="divider"></div>

    <!-- Connect -->
    <p class="section-label">
      <span data-lang-en>Connect</span>
      <span data-lang-it>Contatti</span>
    </p>

    <div class="connect-row">
      <a href="https://linkedin.com/in/" target="_blank" rel="noopener noreferrer" class="connect-btn" data-track="linkedin">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" stroke="none">
          <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
        </svg>
        LinkedIn
      </a>
      <a href="mailto:info@keryxdesign.com" class="connect-btn" data-track="email">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" fill="none">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75" />
        </svg>
        Email
      </a>
    </div>

    <div class="divider"></div>

    <!-- After Hours -->
    <p class="section-label">After Hours</p>

    <a href="#" class="link-card" data-track="hotaru42">
      <div class="service-card__row">
        <div class="service-card__icon">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="m9 9 10.5-3m0 6.553v3.75a2.25 2.25 0 0 1-1.632 2.163l-1.32.377a1.803 1.803 0 1 1-.99-3.467l2.31-.66a2.25 2.25 0 0 0 1.632-2.163Zm0 0V2.25L9 5.25v10.303m0 0v3.75a2.25 2.25 0 0 1-1.632 2.163l-1.32.377a1.803 1.803 0 0 1-.99-3.467l2.31-.66A2.25 2.25 0 0 0 9 15.553Z" />
          </svg>
        </div>
        <div class="service-card__content">
          <div class="service-card__title">Hotaru42</div>
          <div class="service-card__desc">
            <span data-lang-en>Music Project</span>
            <span data-lang-it>Progetto Musicale</span>
          </div>
        </div>
        <div class="service-card__arrow">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" /></svg>
        </div>
      </div>
    </a>

    <!-- Footer -->
    <footer class="footer">
      <div class="status">
        <span class="status-dot"></span>
        <span data-lang-en>Available for projects</span>
        <span data-lang-it>Disponibile per progetti</span>
      </div>
    </footer>
  </div>

  <!-- WhatsApp FAB -->
  <a class="whatsapp-fab" id="wa-fab" href="#" target="_blank" rel="noopener noreferrer" data-track="whatsapp">
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
      <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/>
    </svg>
    <span data-lang-en>Chat with me</span>
    <span data-lang-it>Scrivimi</span>
  </a>

  <script>
    // ── i18n ──
    (function() {
      const STORAGE_KEY = 'dave-card-lang';
      const saved = localStorage.getItem(STORAGE_KEY);
      let lang: string;

      if (saved === 'it' || saved === 'en') {
        lang = saved;
      } else {
        const browserLang = (navigator.language || 'en').toLowerCase();
        lang = browserLang.startsWith('it') ? 'it' : 'en';
      }

      function setLang(l: string) {
        lang = l;
        localStorage.setItem(STORAGE_KEY, l);
        document.documentElement.setAttribute('data-lang', l);
        document.documentElement.lang = l;

        document.getElementById('btn-it')!.classList.toggle('active', l === 'it');
        document.getElementById('btn-en')!.classList.toggle('active', l === 'en');

        document.title = 'Dave Filippini — Direct Response Designer';

        const waMsg = l === 'it'
          ? 'Ciao Dave! Ti contatto dal tuo sito personale. Vorrei saperne di più sui tuoi servizi.'
          : "Hi Dave! I found you through your personal site. I'd like to learn more about your services.";
        document.getElementById('wa-fab')!.setAttribute('href',
          'https://wa.me/355695822380?text=' + encodeURIComponent(waMsg));

        const websiteCard = document.getElementById('website-card');
        if (websiteCard) {
          websiteCard.setAttribute('href', l === 'it'
            ? 'https://keryxdesign.com/it/keryxsite'
            : 'https://keryxdesign.com/it/keryxsite');
        }
      }

      setLang(lang);
      document.getElementById('btn-it')!.addEventListener('click', () => setLang('it'));
      document.getElementById('btn-en')!.addEventListener('click', () => setLang('en'));
    })();

    // ── Click Tracking ──
    (function() {
      const CLICKS_KEY = 'dave-card-clicks';

      function getClicks(): Record<string, { count: number; last: string; history: string[] }> {
        try { return JSON.parse(localStorage.getItem(CLICKS_KEY) || '{}'); }
        catch { return {}; }
      }

      function trackClick(name: string) {
        const clicks = getClicks();
        const now = new Date().toISOString();
        if (!clicks[name]) clicks[name] = { count: 0, last: '', history: [] };
        clicks[name].count++;
        clicks[name].last = now;
        clicks[name].history.push(now);
        // Keep only last 100 entries per link
        if (clicks[name].history.length > 100) clicks[name].history = clicks[name].history.slice(-100);
        localStorage.setItem(CLICKS_KEY, JSON.stringify(clicks));
      }

      document.querySelectorAll('[data-track]').forEach(el => {
        el.addEventListener('click', () => {
          const name = (el as HTMLElement).dataset.track!;
          trackClick(name);
        });
      });
    })();
  </script>
</Layout>
