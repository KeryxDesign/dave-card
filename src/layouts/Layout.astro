---
interface Props {
  title: string;
  description?: string;
}

const { title, description = "Entrepreneur & Founder of Keryx Design. Direct response design for businesses that measure results." } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, 'https://davefilippini.com');
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalURL.href} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg?v=2" />
  <link rel="icon" type="image/x-icon" href="/favicon.ico?v=2" />

  <!-- Open Graph / Facebook -->
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonicalURL.href} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content="https://davefilippini.com/dave.jpg" />
  <meta property="og:locale" content="en_US" />
  <meta property="og:locale:alternate" content="it_IT" />
  <meta property="og:site_name" content="Dave Filippini" />

  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content="https://davefilippini.com/dave.jpg" />

  <!-- Additional SEO -->
  <meta name="author" content="Davide Filippini" />
  <meta name="robots" content="index, follow" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;500;600;700&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
  <style is:global>
    *, *::before, *::after {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    :root {
      --bg: #0b1e2d;
      --bg-deep: #071520;
      --surface: #112a3c;
      --surface-hover: #163750;
      --border: #1e3f5a;
      --border-gold: rgba(191, 155, 72, 0.25);
      --gold: #bf9b48;
      --gold-light: #d4b060;
      --gold-muted: rgba(191, 155, 72, 0.6);
      --gold-glow: rgba(191, 155, 72, 0.12);
      --text: #eae5db;
      --text-muted: #a0b0be;
      --text-dim: #6a8498;
      --white: #f5f0e8;
      --navy-text: #0b1e2d;
      --radius: 14px;
      --transition: cubic-bezier(0.4, 0, 0.2, 1);
    }

    html {
      -webkit-font-smoothing: antialiased;
      -moz-osx-font-smoothing: grayscale;
    }

    body {
      font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
      background: var(--bg);
      color: var(--text);
      min-height: 100vh;
    }
  </style>
</head>
<body>
  <slot />
</body>
</html>
